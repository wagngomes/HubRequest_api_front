# Banco de dados (Supabase)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Servidor
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# CORS — URL do frontend
FRONT_URL=http://localhost:3000

# Auth — modo local (dev / standalone)
AUTH_MODE=local
JWT_SECRET=troque-por-uma-chave-segura-com-pelo-menos-32-caracteres
JWT_EXPIRES_IN=8h

# Auth — modo OIDC corporativo (preencher ao integrar com Azure AD / Okta / Keycloak)
# AUTH_MODE=oidc
# OIDC_ISSUER=https://login.microsoftonline.com/{tenant}/v2.0
# OIDC_AUDIENCE=api://seu-app-id
# OIDC_JWKS_URI=https://login.microsoftonline.com/{tenant}/discovery/v2.0/keys

# Mapeamento de claims IdP → perfis internos (preencher quando receber do corporativo)
# CLAIM_ROLE=roles
# CLAIM_SETOR=department

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@seudominio.com.br

# OpenTelemetry — Grafana Cloud (traces + metrics via OTLP)
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-XX-east-1.grafana.net/otlp
OTEL_INSTANCE_ID=1234567
OTEL_API_TOKEN=glc_eyJ...

# Loki — Grafana Cloud (logs)
LOKI_URL=https://logs-prod-XX-east-1.grafana.net
LOKI_USER=1234567
LOKI_PASSWORD=glc_eyJ...
